From 28c04a222f548b546ed318317e489680ce4d6deb Mon Sep 17 00:00:00 2001
From: Frank Hermann <frank@hermann-essen.de>
Date: Tue, 3 Mar 2026 20:20:11 +0100
Subject: [PATCH] fix(config): default stun servers to empty for local-first
 operation

---
 packages/mcp-server/src/config.ts | 9 +++------
 1 file changed, 3 insertions(+), 6 deletions(-)

diff --git a/packages/mcp-server/src/config.ts b/packages/mcp-server/src/config.ts
index 2ca49dc..fec4e45 100644
--- a/packages/mcp-server/src/config.ts
+++ b/packages/mcp-server/src/config.ts
@@ -23,10 +23,7 @@ const ConfigSchema = z.object({
     rejectUnauthorized: z.boolean().default(true), // TLS certificate validation
     // WebRTC configuration
     webrtc: z.object({
-      stunServers: z.array(z.string()).default([
-        'stun:stun.l.google.com:19302',
-        'stun:stun1.l.google.com:19302'
-      ]),
+      stunServers: z.array(z.string()).default([]),
       // Future: TURN servers support
       // turnServers: z.array(z.object({
       //   urls: z.string(),
@@ -34,7 +31,7 @@ const ConfigSchema = z.object({
       //   credential: z.string().optional()
       // })).optional()
     }).default({
-      stunServers: ['stun:stun.l.google.com:19302', 'stun:stun1.l.google.com:19302']
+      stunServers: []
     })
   }),
   comfyui: z.object({
@@ -73,7 +70,7 @@ const rawConfig = {
     webrtc: {
       stunServers: process.env.FOUNDRY_STUN_SERVERS
         ? process.env.FOUNDRY_STUN_SERVERS.split(',')
-        : ['stun:stun.l.google.com:19302', 'stun:stun1.l.google.com:19302']
+        : []
     }
   },
   comfyui: {
-- 
