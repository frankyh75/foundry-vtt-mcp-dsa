# Foundry MCP Integration Environment Configuration

# =============================================================================
# ChatGPT HTTP Bridge (required for Docker Compose quickstart)
# =============================================================================
MCP_AUTH_TOKEN=change-me
MCP_HTTP_PORT=3333

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=simple
ENABLE_FILE_LOGGING=false
# LOG_FILE_PATH=./logs/mcp-server.log

# =============================================================================
# Foundry VTT Connection Settings
# =============================================================================
# For Docker Desktop on Windows/Mac, use host.docker.internal to reach the host.
FOUNDRY_HOST=host.docker.internal
FOUNDRY_PORT=31415
FOUNDRY_NAMESPACE=/foundry-mcp
FOUNDRY_CONNECTION_TIMEOUT=10000

# Reconnection Settings
FOUNDRY_RECONNECT_ATTEMPTS=5
FOUNDRY_RECONNECT_DELAY=1000

# =============================================================================
# MCP Server Settings
# =============================================================================
SERVER_NAME=foundry-mcp-server
SERVER_VERSION=0.4.11

# =============================================================================
# Development Settings
# =============================================================================
NODE_ENV=production

# Enable debug logging for development
# LOG_LEVEL=debug
# LOG_FORMAT=json
# ENABLE_FILE_LOGGING=true
# LOG_FILE_PATH=./logs/debug.log
